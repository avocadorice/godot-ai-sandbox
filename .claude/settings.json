{
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$PWD/.claude/scripts/log-prompt.sh\""
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$PWD/.claude/scripts/log-session-end.sh\""
          }
        ]
      }
    ]
  }
}
